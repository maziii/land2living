# ============================================================
# L2L — Environment Variables
# Copy this file to .env and fill in values for local dev.
# NEVER commit .env — it is in .gitignore.
# ============================================================

# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
# Used in password reset email links — set to the frontend origin.
APP_URL=http://localhost:3001

# ── Web Council (Vite) ────────────────────────────────────────
# Slug of the council this deployment serves (used at login).
VITE_TENANT_SLUG=ndebele
# Sentry DSN for the web app. Leave blank in local dev.
VITE_SENTRY_DSN=

# ── PostgreSQL 16 ─────────────────────────────────────────────
# Full connection string for Prisma
DATABASE_URL=postgresql://l2l:l2l_dev@localhost:5433/l2l

# Individual vars used by docker-compose.yml — port 5433 avoids conflict with any local Postgres
POSTGRES_USER=l2l
POSTGRES_PASSWORD=l2l_dev
POSTGRES_DB=l2l
POSTGRES_PORT=5433

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ── Object Storage ────────────────────────────────────────────
# Local dev: MinIO. Production: AWS S3 (af-south-1).
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=l2l-documents
S3_ACCESS_KEY_ID=l2l_minio
S3_SECRET_ACCESS_KEY=l2l_minio_dev
S3_REGION=af-south-1
S3_FORCE_PATH_STYLE=true

# MinIO docker-compose vars (local dev only)
MINIO_ROOT_USER=l2l_minio
MINIO_ROOT_PASSWORD=l2l_minio_dev
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Auth (JWT) ────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-generate-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=change-me-in-production-generate-with-openssl-rand-hex-32-refresh
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=30d

# ── Resident ID number encryption ────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of SA ID numbers at rest.
# Generate with: openssl rand -hex 32
RESIDENT_ID_ENCRYPTION_KEY=

# ── Cryptographic PTO Signing ─────────────────────────────────
# Production: AWS KMS (af-south-1). Local dev: env-var Ed25519 keys.
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
KMS_KEY_ALIAS_PREFIX=alias/l2l-tenant
# Set to "local" in dev to use env-var key pairs instead of KMS.
SIGNING_BACKEND=local
# Per-tenant Ed25519 key pairs for local dev (SIGNING_BACKEND=local).
# Replace NDEBELE with your tenant slug in UPPER_CASE.
# Generate with:
#   node -e "const {generateKeyPairSync}=require('crypto');
#     const kp=generateKeyPairSync('ed25519');
#     console.log('PRIVATE='+kp.privateKey.export({type:'pkcs8',format:'der'}).toString('base64'));
#     console.log('PUBLIC='+kp.publicKey.export({type:'spki',format:'der'}).toString('base64'))"
TENANT_SIGNING_KEY_PRIVATE_NDEBELE=
TENANT_SIGNING_KEY_PUBLIC_NDEBELE=

# ── Email ─────────────────────────────────────────────────────
# Production: AWS SES. Local dev: MailHog (http://localhost:8025).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@l2l.local
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ── WhatsApp ──────────────────────────────────────────────────
# Production: Meta WhatsApp Business API via 360dialog.
# Leave blank in local dev — notifications are logged but not sent.
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── SMS ───────────────────────────────────────────────────────
# Leave blank in local dev — SMS is logged but not sent.
SMS_API_URL=
SMS_API_TOKEN=

# ── Payments / Escrow ─────────────────────────────────────────
# PSP selection: yoco | ozow (decided before WP-04 starts)
PSP_PROVIDER=
PSP_API_KEY=
PSP_WEBHOOK_SECRET=

# ── Observability ─────────────────────────────────────────────
# Production: Sentry DSN. Leave blank in local dev.
SENTRY_DSN=
