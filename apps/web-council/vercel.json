{
  "framework": "vite",
  "buildCommand": "cd ../.. && npm ci && npm run build --workspace=apps/web-council",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-api.up.railway.app/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
