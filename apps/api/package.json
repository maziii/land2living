{
  "name": "@l2l/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:public": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:generate:tenant": "prisma generate --schema prisma/tenant/schema.prisma",
    "db:migrate:tenant": "prisma migrate deploy --schema prisma/tenant/schema.prisma"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@fastify/jwt": "^9.0.3",
    "@fastify/multipart": "^9.4.0",
    "@l2l/shared-schemas": "*",
    "@l2l/shared-types": "*",
    "@prisma/client": "^6.2.1",
    "@sentry/node": "^10.51.0",
    "@types/speakeasy": "^2.0.10",
    "argon2": "^0.41.1",
    "bullmq": "^5.76.5",
    "fastify": "^5.2.1",
    "nodemailer": "^8.0.7",
    "pino": "^9.6.0",
    "puppeteer": "^24.42.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
